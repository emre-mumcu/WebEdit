@model List<WebDocViewModel>

<h2>Web Documents <span class="fs-6 text-muted">Default Editor</span></h2>

<a asp-action="Edit">Yeni</a>

@if (Model.Count > 0)
{
	<div class="table-responsive">

		<table class="table table-striped table-hover">

			<thead>
				<tr>
					<th></th>
					<th>ID</th>
					<th>Title</th>
					<th>Tags</th>
					<th>Source</th>
					<th>View Count</th>
					<th>CreatedAt</th>
					<th>UpdatedAt</th>
					<th>CreatedBy</th>
					<th>UpdatedBy</th>
				</tr>
			</thead>

			<tbody>
				@foreach (var item in Model)
				{
					<tr>
						<td>
							<a class="d-block" asp-action="ViewContent" asp-route-protectedId="@item.ProtectedId"><i
								class="bi bi-eye"></i></a>
								<a class="d-block" asp-action="Edit" asp-route-protectedId="@item.ProtectedId"><i
									class="bi bi-pencil"></i></a>
									<a class="d-block" asp-action="Delete" asp-route-protectedId="@item.ProtectedId"><i
										class="bi bi-trash"></i></a>
									</td>
									<td>@item.Id</td>
									<td>@item.Title</td>
									<td>@item.Tags</td>
									<td>@item.Source</td>
									<td>@item.ViewCount</td>
									<td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
									<td>@item.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</td>
									<td>@item.CreatedBy</td>
									<td>@item.UpdatedBy</td>
								</tr>
							}
						</tbody>

					</table>

				</div>
			}
else
			{
				<p>No Records!</p>
			}

