@model List<WebDocViewModel>

<h2>Custom Editor</h2>

@if (Model.Count > 0)
{
	<a asp-action="Edit">Yeni</a>

	<div class="table-responsive">

		<table class="table table-striped table-hover">

			<thead>
			<tr>
				<th></th>
				<th>ID</th>
				<th>Title</th>
				<th>Tags</th>
				<th>Source</th>
				<th>View Count</th>
				<th>CreatedAt</th>
				<th>UpdatedAt</th>
				<th>CreatedBy</th>
				<th>UpdatedBy</th>
			</tr>
			</thead>

			<tbody>
			@foreach (var item in Model)
			{
				<tr>
					<td>
						<a class="d-block" asp-action="ViewContent" asp-route-protectedId="@item.ProtectedId">
							<i
								class="bi bi-eye"></i></a>
						<a class="d-block" asp-action="Edit" asp-route-protectedId="@item.ProtectedId">
							<i
								class="bi bi-pencil"></i></a>
						<a class="d-block" asp-action="Delete" asp-route-protectedId="@item.ProtectedId">
							<i
								class="bi bi-trash"></i></a>
					</td>
					<td>@item.Id</td>
					<td>@item.Title</td>
					<td>@item.Tags</td>
					<td>@item.Source</td>
					<td>@item.ViewCount</td>
					<td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
					<td>@item.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</td>
					<td>@item.CreatedBy</td>
					<td>@item.UpdatedBy</td>
				</tr>
			}
			</tbody>

		</table>

	</div>
}
else
{
	<section class="jumbotron">
		<h1>Kayıt Bulunamadı</h1>
		<p>Veri tabanı şu anda boş. Lütfen görüntülenmek için bir kayıt ekleyiniz.</p>
		<a asp-action="Edit" class="btn btn-primary btn-lg">Yeni Kayıt</a>
	</section>
}