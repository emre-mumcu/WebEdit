@inject IWebHostEnvironment WebHostEnvironment

@functions {

	private List<string> GetBootswatchStyles()
	{
		var wwwroot = WebHostEnvironment.WebRootPath;

		var dirs = new DirectoryInfo(System.IO.Path.Combine(wwwroot, "lib/bootswatch")).GetDirectories().ToList();
		return dirs.Select(i => i.Name).ToList();
	}

}

<div class="dropdown mx-2">
	<a class="btn btn-warning btn-sm dropdown-toggle pt-2 mb-2" href="#" role="button" data-bs-toggle="dropdown"
	   aria-expanded="false">
		<i class="bi bi-marker-tip"></i> UI Style
	</a>

	<ul class="bw-dropdown dropdown-menu">
		<li>
			<h6 class="dropdown-header">Style List</h6>
		</li>
		@foreach (var s in GetBootswatchStyles())
		{
			<li><a id="bw-theme-@s" class="dropdown-item" href="javascript:void(0);"
			       onclick="ChangeBootswatchTheme(this.textContent)">@s</a></li>
		}
	</ul>
</div>

<style>
	.bw-dropdown.dropdown-menu.show {
		display: grid !important;
		grid-template-columns: repeat(3, 1fr);
		min-width: 400px;
	}

</style>