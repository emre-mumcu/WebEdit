<script src="@Url.Content("~/lib/prismjs/prism-core.min.js")"></script>

<script src="@Url.Content("~/lib/prismjs/prism-autoloader.min.js")"></script>

<script src="@Url.Content("~/js/app.js")"></script>

<script src="@Url.Content("~/js/settings.js")"></script>

