@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

<!doctype html>
<html lang="tr">

<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>Web Documents</title>

	<base href="@Url.Content("~/")">
	<meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />

	<partial name="_Styles" />
	@await RenderSectionAsync("Styles", required: false)
</head>

<body>

	<partial name="ImageBg" />

	<div class="d-flex flex-column min-vh-100">

		<partial name="Header" />
		<main class="flex-grow-1 d-flex align-items-stretch">
			<div class="container-lg px-2 px-lg-5 d-flex flex-column flex-grow-1">
				<div class="row flex-grow-1 h-100 my-4">
					<div
						class="col-12 bg-white bg-opacity-10 text-dark-50 p-5 d-flex align-items-start">
						@RenderBody()
					</div>
				</div>
			</div>
		</main>

		<partial name="Footer" />

	</div>

	<partial name="_Scripts" />
	<partial name="_ShowMessage" />

	@await RenderSectionAsync("Scripts", required: false)

</body>

</html>