<!doctype html>
<html lang="tr">

<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>TinyMCE</title>
	<base href="@Url.Content("~/")">
	<partial name="_Styles" />
	@await RenderSectionAsync("Styles", required: false)
</head>

<body class="special-elite">

	<div class="container-lg py-3">
		<header>
			<div class="d-flex flex-column flex-md-row align-items-center pb-3 mb-4 border-bottom">
				<a href="/" class="link-body-emphasis text-decoration-none">
					<span class="fs-4">Web Documents</span>
					<partial name="_PrismTheme" />
					<partial name="_Bootswatch" />
				</a>
				<nav class="d-inline-flex mt-2 mt-md-0 ms-md-auto">
					<a class="me-3 py-2 link-body-emphasis text-decoration-none" asp-controller="Tiny5"
					   asp-action="Index">Default Editor</a>
					<a class="me-3 py-2 link-body-emphasis text-decoration-none" asp-controller="Tiny5Custom"
					   asp-action="Index">Custom Editor</a>
					<select id="imageMode">
						<option value="" selected disabled>Seçiniz</option>
						<option value="server">[Server Upload]</option>
						<option value="base64">Base64</option>
					</select>
				</nav>
			</div>
		</header>

		@RenderBody()

	</div>

	<partial name="_Scripts" />
	@await RenderSectionAsync("Scripts", required: false)

	<script>
			const select = document.getElementById('imageMode');

			const saved = localStorage.getItem('imageUploadMode');



			if (saved) {
				select.value = saved;
			}
			document.getElementById('imageMode').addEventListener('change', e => {
				localStorage.setItem('imageUploadMode', e.target.value);
				select.value = e.target.value;
			});
	</script>

</body>

</html>