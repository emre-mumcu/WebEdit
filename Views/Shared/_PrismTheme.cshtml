@inject IWebHostEnvironment WebHostEnvironment

@functions {

	private List<string> GetPrismStyles()
	{
		var wwwroot = WebHostEnvironment.WebRootPath;

		var cssFiles = Directory.GetFiles(System.IO.Path.Combine(wwwroot, "lib/prismjs/themes"), "*.css")
			.Select(System.IO.Path.GetFileNameWithoutExtension)
			.OfType<string>()
			// .Select(x => x[3..])
			.ToList();

		return cssFiles;
	}

}

<div class="dropdown mx-2">
	<a class="btn btn-warning btn-sm dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
	   aria-expanded="false">
		<i class="bi bi-marker-tip"></i> Code Style
	</a>

	<ul class="prism-dropdown dropdown-menu">
		<li>
			<h6 class="dropdown-header">Style List</h6>
		</li>
		@foreach (var s in GetPrismStyles())
		{
			<li><a id="prism-theme-@s" class="dropdown-item" href="javascript:void(0);" onclick="ChangePrismTheme(this.textContent)">@s</a></li>
		}
	</ul>
</div>

<style>
	.prism-dropdown.dropdown-menu.show {
		display: grid !important;
		grid-template-columns: repeat(3, 1fr);
		min-width: 400px;
	}
</style>






